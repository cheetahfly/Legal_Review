<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- H11: 全局禁止明文 HTTP，避免 API Key 在 API 26-27 设备上明文传输 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
